# ====== إعدادات الخادم ======
PORT=5000
NODE_ENV=development

# رابط الواجهة الأمامية (للسماح بـ CORS وروابط المشاركة)
CLIENT_URL=http://localhost:5173

# الرابط العام للموقع (يُستخدم في sitemap و Open Graph)
PUBLIC_SITE_URL=http://localhost:5173

# ====== قاعدة البيانات PostgreSQL ======
# إما تضع DATABASE_URL كامل (مفضّل عند النشر على Render/Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clothing_store
# أو القيم المنفصلة (تُستخدم فقط إذا لم يوجد DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=clothing_store
# عند النشر السحابي غالباً تحتاج SSL
PGSSL=false

# ====== أسرار الجلسات (غيّرها لقيم عشوائية طويلة!) ======
# ولّد قيمة قوية بالأمر: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_value
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false
# عند النشر عبر دومينين مختلفين (Vercel + Render) اجعلها none، وإلا lax
COOKIE_SAMESITE=lax

# ====== الاشتراكات (تفعيل يدوي + دفع محلي) ======
# تفعيل إلزام الاشتراك (true) أو تعطيله مؤقتاً (false)
SUBSCRIPTIONS_ENABLED=true
# بريد/بُرُد المديرين (مفصولة بفاصلة) — يرون لوحة الإدارة ويفعّلون الاشتراكات
ADMIN_EMAIL=
# تعليمات الدفع التي تظهر للمشترك (Payoneer / تحويل بنكي / محفظة محلية)
ADMIN_PAYMENT_INFO=للاشتراك: حوّل المبلغ عبر Payoneer إلى (بريدك) أو محفظة PalPay رقم (xxxx)، ثم أرسل رقم العملية وسيُفعّل حسابك خلال ساعات.

# ====== البريد (استعادة كلمة المرور عبر Gmail) ======
# فعّل التحقق بخطوتين على Gmail ثم أنشئ "App Password" وضعه هنا
EMAIL_USER=
EMAIL_PASS=

# ====== IndexNow (تسريع فهرسة جوجل/بنج) ======
# ولّد مفتاح: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
INDEXNOW_KEY=
